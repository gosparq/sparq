# ==============================================================================
# sparQ — Environment Configuration
# ==============================================================================
# Copy to .env in this directory (auto-created on first run if missing).
# Only SECRET_KEY is required for production. Everything else has sensible
# defaults or is optional.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core
# ------------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=false
# SESSION_COOKIE_SECURE=true   # Enable when serving over HTTPS

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# Default: SQLite at data/sparq.db (zero-config).
# For PostgreSQL, uncomment and set the connection string:
# DATABASE_URL=postgresql://sparq:sparq@localhost:5432/sparq

# Data directory (default: ./data). Override for Docker or custom paths.
# SPARQ_DATA_DIR=/data

# ------------------------------------------------------------------------------
# AI Assistant (optional)
# ------------------------------------------------------------------------------
# Enables the sparQy AI features. Without a key, AI is disabled.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ------------------------------------------------------------------------------
# Email / SMTP (optional)
# ------------------------------------------------------------------------------
# Required for signup confirmation emails and notifications.
# Without SMTP, signup creates accounts immediately (no email verification).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@example.com

# ------------------------------------------------------------------------------
# Email Gateway (optional)
# ------------------------------------------------------------------------------
# Fallback HTTP relay used ONLY when no SMTP / sparQ Mail provider above is set
# AND both vars below are set. A configured provider always takes priority.
#
# SPARQ_GATEWAY_URL=https://mail.example.com
# SPARQ_GATEWAY_BYPASS_TOKEN=
# SPARQ_GATEWAY_SITE_ID=sparq          # optional, defaults to "sparq"
# SPARQ_GATEWAY_FROM_NAME=sparQ        # optional, defaults to "sparQ"

# ------------------------------------------------------------------------------
# Web Push Notifications (optional)
# ------------------------------------------------------------------------------
# Generate VAPID keys: pip install py-vapid && vapid --gen
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CLAIMS_EMAIL=admin@example.com

# ------------------------------------------------------------------------------
# GitHub Integration (optional)
# ------------------------------------------------------------------------------
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=            # PEM string or base64-encoded PEM
# GITHUB_APP_SLUG=                   # App slug from github.com/apps/<slug>
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_WEBHOOK_SECRET=             # Shared secret for verifying inbound webhooks (required in production)
# GITHUB_WEBHOOK_BASE_URL=          # Public base URL for webhook delivery, e.g. https://app.example.com
                                    # Set behind a reverse proxy or for an ngrok tunnel; otherwise derived from the request host

# ------------------------------------------------------------------------------
# MSA — Multi-workspace System Admin (optional)
# ------------------------------------------------------------------------------
# Server admin panel at /msa for managing orgs, workspaces, and users.
# Disabled by default. Set both to enable.
# MSA_USER=
# MSA_PASS=

# ------------------------------------------------------------------------------
# Update Check (optional)
# ------------------------------------------------------------------------------
# sparQ checks gosparq.com about once a day for a newer version and logs when
# one is available. It transmits nothing about your instance. Enabled by default.
# SPARQ_UPDATE_CHECK=false                                   # disable the check
# SPARQ_UPDATE_URL=https://www.gosparq.com/api/latest-version   # override endpoint

# ------------------------------------------------------------------------------
# WebSocket CORS (optional)
# ------------------------------------------------------------------------------
# Default: "*" in debug, same-origin in production.
# SOCKETIO_CORS_ORIGINS=https://app.example.com
